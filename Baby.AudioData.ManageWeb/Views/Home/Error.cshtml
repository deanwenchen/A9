@model Leo.Core.ErrorViewInfo
@using Leo.Core
@{
    ViewData["Title"] = "Error";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section id="pageerror" class="app-main">
    <div class="errPage-container">
        <el-button type="primary" icon="el-icon-arrow-left" v-if="hasBack" @@click="back">返回</el-button>
        <el-row>
            <el-col :span="12">
                <h1 class="text-jumbo text-ginormous" style="font-size:100px;">
                    Error
                </h1>
                <h2>@Html.Raw(Model.JsonSerialize())</h2>
            </el-col>
            <el-col :span="12"><img src="~/imgs/404.gif" width="313" height="428"></el-col>
        </el-row>
    </div>
</section>

<script type="text/javascript">
    createVueApp({
        el: '#pageerror',
        data() {
            return {
                hasBack: true
            }
        },
        mounted() {
            if (window.parent.modalPageTemplate) {
                this.hasBack = false;
                window.parent.modalPageTemplate.dialogLoading = false;
            }
        },
        methods: {
            back() {
                window.history.go(-1);
            }
        }
    })
</script>